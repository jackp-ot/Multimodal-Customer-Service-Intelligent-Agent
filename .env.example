# ============================================
# AI Agent RAG 环境变量配置
# 复制此文件为 .env 并填入真实值
# ============================================

# LLM API 配置 (阿里云 DashScope / OpenAI 兼容)
API_KEY=your_api_key_here
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名称
CHAT_MODEL_NAME=deepseek-v4-flash
VISION_MODEL_NAME=qwen-vl-plus
EMBEDDING_MODEL_NAME=text-embedding-v4

# Milvus 向量数据库配置
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_TOKEN=
MILVUS_COLLECTION_NAME=QA_agent
